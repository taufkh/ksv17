<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_purchase_request_line_make_purchase_order" model="ir.ui.view">
        <field name="name">purchase.request.line.make.purchase.order.vendor.moq</field>
        <field name="model">purchase.request.line.make.purchase.order</field>
        <field name="inherit_id" ref="purchase_request.view_purchase_request_line_make_purchase_order" />
        <field name="arch" type="xml">
            <field name="supplier_id" position="after">
                <field
                    name="vendor_moq_qty"
                    readonly="1"
                    invisible="not vendor_moq_qty"
                />
                <div
                    class="text-muted"
                    colspan="2"
                    invisible="not vendor_moq_qty"
                >
                    Dibaca dalam Purchase UoM produk yang dipilih.
                </div>
                <field
                    name="vendor_moq_note"
                    readonly="1"
                    invisible="not vendor_moq_note"
                    placeholder="Vendor MOQ notes"
                />
            </field>
        </field>
    </record>
</odoo>
