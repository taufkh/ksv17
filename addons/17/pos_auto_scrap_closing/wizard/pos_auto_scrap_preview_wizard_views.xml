<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_auto_scrap_preview_wizard_form" model="ir.ui.view">
        <field name="name">pos.auto.scrap.preview.wizard.form</field>
        <field name="model">pos.auto.scrap.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Auto Scrap Preview" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="session_id"/>
                        <field name="product_count"/>
                        <field name="total_qty"/>
                        <field name="total_estimated_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </group>
                    <field name="note" nolabel="1" readonly="1" widget="text" invisible="not note"/>
                    <field name="line_ids" nolabel="1" readonly="1">
                        <tree create="0" delete="0" edit="0">
                            <field name="product_id"/>
                            <field name="location_id"/>
                            <field name="lot_id" optional="hide"/>
                            <field name="scrap_qty"/>
                            <field name="product_uom_id"/>
                            <field name="estimated_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </tree>
                    </field>
                    <div class="text-muted" invisible="line_ids">
                        Tidak ada stok sisa yang memenuhi kriteria auto scrap untuk session ini.
                    </div>
                </sheet>
                <footer>
                    <button string="Close" special="cancel" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
