<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_auto_scrap_approval_wizard_form" model="ir.ui.view">
        <field name="name">pos.auto.scrap.approval.wizard.form</field>
        <field name="model">pos.auto.scrap.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Approve Auto Scrap" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="session_id"/>
                        <field name="loss_limit" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        <field name="projected_loss_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </group>
                    <field
                        name="reason"
                        placeholder="Jelaskan alasan approval untuk loss di atas threshold ini."
                    />
                </sheet>
                <footer>
                    <button name="action_confirm" string="Approve" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
