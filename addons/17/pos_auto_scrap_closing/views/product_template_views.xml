<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_auto_scrap" model="ir.ui.view">
        <field name="name">product.template.form.auto.scrap.closing</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="point_of_sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='pos']/field[@name='available_in_pos']" position="after">
                <field
                    name="auto_scrap_on_pos_closing"
                    invisible="not available_in_pos or detailed_type != 'product'"
                />
            </xpath>
        </field>
    </record>
</odoo>
