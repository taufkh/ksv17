<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_bakery_roles" model="ir.module.category">
        <field name="name">Bakery Roles</field>
        <field name="description">Operational roles for bakery users</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_bakery_purchase_user" model="res.groups">
        <field name="name">Purchase User</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('purchase.group_purchase_user'))]"
        />
    </record>

    <record id="group_bakery_purchase_manager" model="res.groups">
        <field name="name">Purchase Manager</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('purchase.group_purchase_manager'))]"
        />
    </record>

    <record id="group_bakery_warehouse_user" model="res.groups">
        <field name="name">Warehouse User</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('stock.group_stock_user'))]"
        />
    </record>

    <record id="group_bakery_warehouse_admin" model="res.groups">
        <field name="name">Warehouse Admin</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('stock.group_stock_manager'))]"
        />
    </record>

    <record id="group_bakery_baker_user" model="res.groups">
        <field name="name">Baker User</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('mrp.group_mrp_user')), (4, ref('stock.group_stock_user'))]"
        />
    </record>

    <record id="group_bakery_baker_supervisor" model="res.groups">
        <field name="name">Baker Supervisor</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('mrp.group_mrp_manager')), (4, ref('stock.group_stock_user'))]"
        />
    </record>

    <record id="group_bakery_cashier" model="res.groups">
        <field name="name">Cashier</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('point_of_sale.group_pos_user'))]"
        />
    </record>

    <record id="group_bakery_cashier_supervisor" model="res.groups">
        <field name="name">Cashier Supervisor</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('point_of_sale.group_pos_manager'))]"
        />
    </record>

    <record id="group_bakery_finance" model="res.groups">
        <field name="name">Finance</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('account.group_account_manager'))]"
        />
    </record>

    <record id="group_bakery_owner" model="res.groups">
        <field name="name">Owner</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field
            name="implied_ids"
            eval="[
                (4, ref('purchase.group_purchase_manager')),
                (4, ref('stock.group_stock_manager')),
                (4, ref('mrp.group_mrp_manager')),
                (4, ref('point_of_sale.group_pos_manager')),
                (4, ref('base.group_user')),
                (4, ref('account.group_account_manager'))
            ]"
        />
    </record>

    <record id="group_bakery_investor_portal" model="res.groups">
        <field name="name">Investor Portal</field>
        <field name="category_id" ref="bakery_user_roles.module_category_bakery_roles"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>
</odoo>
