<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_template_only_form_view_purchase_packaging" model="ir.ui.view">
        <field name="name">product.template.only.form.purchase.packaging</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="after">
                <page name="purchase_packaging" string="Purchase Packs">
                    <div class="text-muted" invisible="product_variant_count != 1">
                        Gunakan pack per product untuk label seperti PACK, DUS, BOTOL, atau GALON
                        yang isi konversinya berbeda-beda. Tandai satu pack sebagai default purchase
                        agar terpilih otomatis di purchase order line.
                    </div>
                    <field
                        name="packaging_ids"
                        invisible="product_variant_count != 1"
                        context="{'tree_view_ref': 'product.product_packaging_tree_view2', 'form_view_ref': 'product.product_packaging_form_view2'}"
                    />
                    <div class="text-muted" invisible="product_variant_count == 1">
                        Produk ini memiliki beberapa variant. Konfigurasi purchase pack dilakukan di level variant,
                        bukan di template.
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
