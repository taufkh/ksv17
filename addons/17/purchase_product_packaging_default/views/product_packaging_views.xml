<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_packaging_tree_view_purchase_default" model="ir.ui.view">
        <field name="name">product.packaging.tree.view.purchase.default</field>
        <field name="model">product.packaging</field>
        <field name="inherit_id" ref="product.product_packaging_tree_view" />
        <field name="arch" type="xml">
            <field name="qty" position="after">
                <field name="purchase" optional="show" />
                <field
                    name="purchase_is_default"
                    optional="show"
                    invisible="not purchase"
                />
            </field>
        </field>
    </record>

    <record id="product_packaging_form_view_purchase_default" model="ir.ui.view">
        <field name="name">product.packaging.form.view.purchase.default</field>
        <field name="model">product.packaging</field>
        <field name="inherit_id" ref="product.product_packaging_form_view" />
        <field name="arch" type="xml">
            <field name="barcode" position="after">
                <field name="purchase" />
                <field
                    name="purchase_is_default"
                    invisible="not purchase"
                />
            </field>
        </field>
    </record>
</odoo>
