<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_pos_sales_simulation_company" model="ir.rule">
        <field name="name">POS sales simulation multi-company</field>
        <field name="model_id" ref="model_pos_sales_simulation"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('point_of_sale.group_pos_user')), (4, ref('point_of_sale.group_pos_manager'))]"/>
    </record>

