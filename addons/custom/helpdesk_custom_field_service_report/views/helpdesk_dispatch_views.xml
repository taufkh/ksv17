<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_dispatch_form_field_service_report" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.form.field.service.report</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="inherit_id" ref="helpdesk_custom_dispatch.view_helpdesk_dispatch_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_create_service_report"
                    type="object"
                    string="Create Service Report"
                    invisible="state in ('draft', 'cancelled')"
                    groups="helpdesk_mgmt.group_helpdesk_user"
                />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_service_reports"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-clipboard"
                    groups="helpdesk_mgmt.group_helpdesk_user"
                >
                    <field name="service_report_count" widget="statinfo" string="Service Reports" />
                </button>
            </xpath>
            <xpath expr="//field[@name='location']/ancestor::group[2]" position="after">
                <group string="Service Report Summary">
                    <group>
                        <field name="service_report_count" readonly="1" />
                        <field name="latest_service_report_state" readonly="1" />
                    </group>
                    <group>
                        <field name="customer_acknowledged_report" readonly="1" />
                    </group>
                </group>
            </xpath>
            <xpath expr="//field[@name='followup_action']/ancestor::page[1]" position="after">
                <page string="Service Reports">
                    <field name="service_report_ids" readonly="1">
                        <tree>
                            <field name="name" />
                            <field name="service_date" />
                            <field name="visit_outcome" />
                            <field name="checklist_completion" />
                            <field name="customer_acknowledged" />
                            <field name="state" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
