<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_release_note_search" model="ir.ui.view">
        <field name="name">helpdesk.release.note.search</field>
        <field name="model">helpdesk.release.note</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="version" />
                <field name="team_id" />
                <field name="owner_id" />
                <field name="release_type" />
                <field name="severity" />
                <filter string="Rolled Out" name="rolled_out" domain="[('state', '=', 'rolled_out')]" />
                <filter string="Communicated" name="communicated" domain="[('state', '=', 'communicated')]" />
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                    <filter string="Type" name="group_type" context="{'group_by': 'release_type'}" />
                    <filter string="Severity" name="group_severity" context="{'group_by': 'severity'}" />
                    <filter string="Team" name="group_team" context="{'group_by': 'team_id'}" />
                    <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_helpdesk_release_note_tree" model="ir.ui.view">
        <field name="name">helpdesk.release.note.tree</field>
        <field name="model">helpdesk.release.note</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="version" />
                <field name="state" />
                <field name="release_type" />
                <field name="severity" />
                <field name="release_date" optional="show" />
                <field name="team_id" optional="show" />
                <field name="problem_count" />
                <field name="ticket_count" />
                <field name="open_ticket_count" optional="show" />
                <field name="communication_count" optional="show" />
                <field name="owner_id" optional="show" />
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_release_note_form" model="ir.ui.view">
        <field name="name">helpdesk.release.note.form</field>
        <field name="model">helpdesk.release.note</field>
        <field name="arch" type="xml">
            <form string="Release Note">
                <header>
                    <button name="action_mark_planned" type="object" string="Plan" invisible="state not in ('draft')" />
                    <button name="action_mark_in_progress" type="object" string="Start Rollout" invisible="state not in ('draft', 'planned')" />
                    <button name="action_mark_rolled_out" type="object" string="Mark Rolled Out" class="btn-primary" invisible="state not in ('planned', 'in_progress')" />
                    <button name="action_log_customer_update" type="object" string="Log Customer Update" invisible="state not in ('rolled_out', 'communicated')" />
                    <button name="action_close" type="object" string="Close" invisible="state not in ('communicated')" groups="helpdesk_mgmt.group_helpdesk_manager" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,planned,in_progress,rolled_out,communicated,closed" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_problems" type="object" class="oe_stat_button" icon="fa-bug">
                            <field name="problem_count" widget="statinfo" string="Problems" />
                        </button>
                        <button name="action_open_tickets" type="object" class="oe_stat_button" icon="fa-life-ring">
                            <field name="ticket_count" widget="statinfo" string="Tickets" />
                        </button>
                        <button name="action_open_knowledge_articles" type="object" class="oe_stat_button" icon="fa-book">
                            <field name="knowledge_article_count" widget="statinfo" string="Knowledge" />
                        </button>
                        <button name="action_open_communication_logs" type="object" class="oe_stat_button" icon="fa-comments">
                            <field name="communication_count" widget="statinfo" string="Comms" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1><field name="name" /></h1>
                        <h2><field name="version" placeholder="2026.03.30-patch-02" /></h2>
                    </div>
                    <group>
                        <group>
                            <field name="release_type" />
                            <field name="severity" />
                            <field name="release_date" />
                            <field name="communication_due_date" />
                        </group>
                        <group>
                            <field name="team_id" />
                            <field name="owner_id" />
                            <field name="company_id" />
                            <field name="open_ticket_count" readonly="1" />
                        </group>
                    </group>
                    <group>
                        <field name="summary" />
                    </group>
                    <notebook>
                        <page string="Scope">
                            <group>
                                <field name="problem_ids" widget="many2many_tags" options="{'no_create': True}" />
                                <field name="ticket_ids" widget="many2many_tags" options="{'no_create': True}" />
                                <field name="knowledge_article_ids" widget="many2many_tags" options="{'no_create': True}" />
                            </group>
                        </page>
                        <page string="Technical Notes">
                            <field name="technical_notes" widget="html" />
                        </page>
                        <page string="Rollout Notes">
                            <field name="rollout_notes" widget="html" />
                        </page>
                        <page string="Customer Message">
                            <field name="customer_message" widget="html" />
                        </page>
                        <page string="Communication Log">
                            <field name="communication_log_ids" readonly="1">
                                <tree>
                                    <field name="logged_at" />
                                    <field name="ticket_id" />
                                    <field name="channel" />
                                    <field name="direction" />
                                    <field name="status" />
                                    <field name="subject" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_release_note" model="ir.actions.act_window">
        <field name="name">Release Notes</field>
        <field name="res_model">helpdesk.release.note</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_helpdesk_release_note_search" />
    </record>

    <menuitem
        id="menu_helpdesk_release_note"
        name="Release Notes"
        parent="helpdesk_mgmt.helpdesk_ticket_reporting_menu"
        action="action_helpdesk_release_note"
        sequence="49"
        groups="helpdesk_mgmt.group_helpdesk_user"
    />
</odoo>
