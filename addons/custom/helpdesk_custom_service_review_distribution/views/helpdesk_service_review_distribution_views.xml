<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_service_review_distribution_search" model="ir.ui.view">
        <field name="name">helpdesk.service.review.distribution.search</field>
        <field name="model">helpdesk.service.review.distribution</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="partner_id" />
                <filter string="Active" name="active" domain="[('active', '=', True)]" />
                <filter string="Due Now" name="due_now" domain="[('next_run_date', '&lt;=', context_today())]" />
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}" />
                    <filter string="Schedule" name="group_schedule" context="{'group_by': 'schedule_type'}" />
                    <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_helpdesk_service_review_distribution_tree" model="ir.ui.view">
        <field name="name">helpdesk.service.review.distribution.tree</field>
        <field name="model">helpdesk.service.review.distribution</field>
        <field name="arch" type="xml">
            <tree decoration-muted="not active">
                <field name="active" column_invisible="1" />
                <field name="name" />
                <field name="partner_id" />
                <field name="schedule_type" />
                <field name="period_mode" />
                <field name="next_run_date" />
                <field name="last_run_at" optional="show" />
                <field name="state" />
                <field name="email_to" optional="show" />
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_service_review_distribution_form" model="ir.ui.view">
        <field name="name">helpdesk.service.review.distribution.form</field>
        <field name="model">helpdesk.service.review.distribution</field>
        <field name="arch" type="xml">
            <form string="Service Review Distribution">
                <header>
                    <button name="action_activate" type="object" string="Activate" class="btn-primary" invisible="active and state == 'active'" />
                    <button name="action_pause" type="object" string="Pause" invisible="not active" />
                    <button name="action_run_now" type="object" string="Run Now" class="btn-secondary" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,paused" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="partner_id" />
                            <field name="recipient_ids" widget="many2many_tags" />
                            <field name="email_to" readonly="1" />
                        </group>
                        <group>
                            <field name="owner_id" />
                            <field name="schedule_type" />
                            <field name="period_mode" />
                            <field name="next_run_date" />
                            <field name="last_run_at" readonly="1" />
                            <field name="last_pack_id" readonly="1" />
                            <field name="last_mail_id" readonly="1" />
                            <field name="active" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note" widget="html" nolabel="1" />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="action_helpdesk_service_review_distribution" model="ir.actions.act_window">
        <field name="name">Service Review Distribution</field>
        <field name="res_model">helpdesk.service.review.distribution</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_helpdesk_service_review_distribution_search" />
    </record>

    <menuitem
        id="menu_helpdesk_service_review_distribution"
        name="Service Review Distribution"
        parent="helpdesk_mgmt.helpdesk_ticket_reporting_menu"
        action="action_helpdesk_service_review_distribution"
        sequence="62"
        groups="helpdesk_mgmt.group_helpdesk_user"
    />
</odoo>
