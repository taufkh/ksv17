<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_project_time_type_tree_helpdesk_invoice" model="ir.ui.view">
        <field name="name">project.time.type.tree.helpdesk.invoice</field>
        <field name="model">project.time.type</field>
        <field name="inherit_id" ref="hr_timesheet_time_type.view_project_time_type_tree" />
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="invoice_product_id" optional="show" />
                <field name="invoice_label" optional="hide" />
            </field>
        </field>
    </record>

    <record id="view_project_time_type_form_helpdesk_invoice" model="ir.ui.view">
        <field name="name">project.time.type.form.helpdesk.invoice</field>
        <field name="model">project.time.type</field>
        <field name="inherit_id" ref="hr_timesheet_time_type.view_project_time_type_form" />
        <field name="arch" type="xml">
            <field name="description" position="after">
                <field name="invoice_product_id" />
                <field name="invoice_label" />
            </field>
        </field>
    </record>
</odoo>
