<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_ticket_merge_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.merge.form</field>
        <field name="model">helpdesk.ticket.merge</field>
        <field name="arch" type="xml">
            <form string="Merge Tickets">
                <group>
                    <field name="ticket_ids" widget="many2many_list">
                        <list>
                            <field name="number"/>
                            <field name="name"/>
                            <field name="stage_id"/>
                        </list>
                    </field>
                    <field name="master_ticket_id"
                           domain="[('id', 'in', ticket_ids)]"/>
                    <field name="merge_description"/>
                </group>
                <footer>
                    <button name="merge_tickets" type="object"
                            string="Merge" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_ticket_merge" model="ir.actions.act_window">
        <field name="name">Merge Tickets</field>
        <field name="res_model">helpdesk.ticket.merge</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
