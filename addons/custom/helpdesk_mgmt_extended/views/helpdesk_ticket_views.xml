<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Kanban: show SLA badge ── -->
    <record id="view_helpdesk_ticket_kanban_ext" model="ir.ui.view">
        <field name="name">helpdesk.ticket.kanban.extended</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.view_helpdesk_ticket_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="quick_create">false</attribute>
            </xpath>
        </field>
    </record>

    <!-- ── List: extra columns ── -->
    <record id="view_helpdesk_ticket_list_ext" model="ir.ui.view">
        <field name="name">helpdesk.ticket.list.extended</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.view_helpdesk_ticket_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='priority']" position="after">
                <field name="type_id" optional="show"/>
                <field name="sla_deadline" optional="show"/>
                <field name="sla_expired" optional="show"
                       decoration-danger="sla_expired"/>
                <field name="rating_status" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- ── Form: comprehensive extension ── -->
    <record id="view_helpdesk_ticket_form_ext" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.extended</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.view_helpdesk_ticket_form"/>
        <field name="arch" type="xml">

            <!-- Smart buttons -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <!-- Sale Orders -->
                <button name="action_open_sale_orders" type="object"
                        class="oe_stat_button" icon="fa-shopping-cart"
                        invisible="so_count == 0">
                    <field name="so_count" widget="statinfo" string="Sales"/>
                </button>
                <!-- Leads -->
                <button name="action_open_leads" type="object"
                        class="oe_stat_button" icon="fa-phone"
                        invisible="lead_count == 0">
                    <field name="lead_count" widget="statinfo" string="Leads"/>
                </button>
                <!-- Tasks -->
                <button name="action_open_tasks" type="object"
                        class="oe_stat_button" icon="fa-tasks"
                        invisible="task_count == 0">
                    <field name="task_count" widget="statinfo" string="Tasks"/>
                </button>
                <!-- Related Tickets -->
                <button name="open_ticket" type="object"
                        class="oe_stat_button" icon="fa-ticket"
                        invisible="not related_ticket_ids">
                    <field string="Related" name="related_ticket_ids" widget="statinfo"/>
                </button>
            </xpath>

            <!-- Header: SLA expiry warning -->
            <xpath expr="//header" position="inside">
                <field name="sla_expired" invisible="True"/>
                <widget name="web_ribbon" title="SLA Expired"
                        bg_color="text-bg-danger"
                        invisible="not sla_expired"/>
            </xpath>

            <!-- Type field near category -->
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="type_id"/>
            </xpath>

            <!-- SLA deadline near priority -->
            <xpath expr="//field[@name='priority']" position="after">
                <field name="sla_deadline" readonly="1"/>
            </xpath>

            <!-- Extended notebook pages -->
            <xpath expr="//notebook" position="inside">

                <!-- Project & Task -->
                <page name="project" string="Project">
                    <group>
                        <field name="project_id"/>
                        <field name="task_id"
                               domain="[('project_id', '=', project_id)]"/>
                    </group>
                </page>

                <!-- Sale Orders -->
                <page name="sale_orders" string="Sale Orders">
                    <field name="sale_order_ids" widget="many2many_list"
                           context="{'default_partner_id': partner_id}">
                        <list>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="amount_total"/>
                            <field name="state"/>
                        </list>
                    </field>
                    <div class="mt-2">
                        <button name="action_create_lead" type="object"
                                string="Create Lead" class="btn btn-secondary btn-sm"
                                icon="fa-plus"/>
                    </div>
                </page>

                <!-- Timesheets -->
                <page name="timesheet" string="Timesheets"
                      invisible="not allow_timesheet">
                    <group>
                        <field name="planned_hours"/>
                        <field name="total_hours" readonly="1"/>
                        <field name="remaining_hours" readonly="1"/>
                        <field name="progress" widget="progressbar" readonly="1"/>
                    </group>
                    <field name="timesheet_ids">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="employee_id"/>
                            <field name="name"/>
                            <field name="unit_amount" widget="timesheet_uom"/>
                        </list>
                    </field>
                </page>

                <!-- Related Tickets -->
                <page name="related_tickets" string="Related Tickets">
                    <field name="related_ticket_ids">
                        <list>
                            <field name="number"/>
                            <field name="name"/>
                            <field name="stage_id"/>
                            <field name="priority"/>
                        </list>
                    </field>
                </page>

                <!-- Activity Tracking -->
                <page name="activity_track" string="Activity">
                    <group>
                        <field name="record_ref"/>
                        <field name="source_activity_type_id"
                               invisible="not record_ref"/>
                        <field name="date_deadline"
                               invisible="not record_ref"/>
                        <field name="assigned_user_id"
                               invisible="not record_ref"/>
                        <field name="next_stage_id"
                               invisible="not record_ref"/>
                    </group>
                </page>

                <!-- Rating -->
                <page name="rating" string="Rating">
                    <group>
                        <field name="rating_status"/>
                        <field name="positive_rate_percentage"/>
                    </group>
                </page>

            </xpath>
        </field>
    </record>

    <!-- ── Search: SLA filter ── -->
    <record id="view_helpdesk_ticket_search_ext" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search.extended</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.view_helpdesk_ticket_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter name="sla_expired" string="SLA Expired"
                        domain="[('sla_expired', '=', True)]"/>
                <filter name="has_sale" string="Has Sale Order"
                        domain="[('sale_order_ids', '!=', False)]"/>
                <filter name="has_lead" string="Has Lead"
                        domain="[('lead_ids', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'type_id'}"/>
                    <filter name="group_rating" string="Rating"
                            context="{'group_by': 'rating_status'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
