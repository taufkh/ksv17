<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_escalation_rule_tree" model="ir.ui.view">
        <field name="name">helpdesk.escalation.rule.tree</field>
        <field name="model">helpdesk.escalation.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="team_id"/>
                <field name="parent_rule_id"/>
                <field name="trigger"/>
                <field name="threshold_hours"/>
                <field name="action"/>
                <field name="target_user_id" optional="show"/>
                <field name="stage_id" optional="hide"/>
                <field name="new_priority" optional="hide"/>
                <field name="event_count" optional="show"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_escalation_rule_form" model="ir.ui.view">
        <field name="name">helpdesk.escalation.rule.form</field>
        <field name="model">helpdesk.escalation.rule</field>
        <field name="arch" type="xml">
            <form string="Escalation Rule">
                <sheet>
                    <field name="team_user_ids" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_events"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-history"
                        >
                            <field name="event_count" widget="statinfo" string="Executions"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="team_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="parent_rule_id"/>
                            <field name="trigger" readonly="parent_rule_id"/>
                            <field name="threshold_hours"/>
                            <field name="action"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field
                                name="target_user_id"
                                invisible="action != 'reassign'"
                            />
                            <field
                                name="stage_id"
                                invisible="action != 'change_stage'"
                            />
                            <field
                                name="new_priority"
                                invisible="action != 'change_priority'"
                            />
                        </group>
                        <group>
                            <field
                                name="notify_user_ids"
                                widget="many2many_tags"
                                options="{'no_create_edit': True}"
                            />
                        </group>
                    </group>
                    <group>
                        <field
                            name="note"
                            placeholder="Internal context for the manager or on-call agent."
                        />
                    </group>
                    <group string="Chain">
                        <field name="child_rule_ids" readonly="1">
                            <tree>
                                <field name="name"/>
                                <field name="threshold_hours"/>
                                <field name="action"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_escalation_event_tree" model="ir.ui.view">
        <field name="name">helpdesk.escalation.event.tree</field>
        <field name="model">helpdesk.escalation.event</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="event_date"/>
                <field name="ticket_id"/>
                <field name="rule_id"/>
                <field name="team_id" optional="show"/>
                <field name="action"/>
                <field name="target_user_id" optional="show"/>
                <field name="executed_by_id" optional="show"/>
                <field name="reason"/>
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_escalation_event_form" model="ir.ui.view">
        <field name="name">helpdesk.escalation.event.form</field>
        <field name="model">helpdesk.escalation.event</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0" string="Escalation Event">
                <sheet>
                    <group>
                        <group>
                            <field name="ticket_id"/>
                            <field name="rule_id"/>
                            <field name="event_date"/>
                        </group>
                        <group>
                            <field name="action"/>
                            <field name="target_user_id"/>
                            <field name="executed_by_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="notify_user_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_escalation_rule" model="ir.actions.act_window">
        <field name="name">Escalation Rules</field>
        <field name="res_model">helpdesk.escalation.rule</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_helpdesk_escalation_event" model="ir.actions.act_window">
        <field name="name">Escalation Events</field>
        <field name="res_model">helpdesk.escalation.event</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_helpdesk_escalation_rule"
        name="Escalation Rules"
        parent="helpdesk_mgmt.helpdesk_ticket_config_main_menu"
        action="action_helpdesk_escalation_rule"
        sequence="20"
        groups="helpdesk_mgmt.group_helpdesk_manager"
    />
</odoo>
