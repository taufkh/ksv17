<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_dispatch_evidence_search" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.evidence.search</field>
        <field name="model">helpdesk.dispatch.evidence</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="dispatch_id" />
                <field name="ticket_id" />
                <field name="partner_id" />
                <field name="engineer_id" />
                <filter string="Photos" name="photos" domain="[('is_photo', '=', True)]" />
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'evidence_type'}" />
                    <filter string="Stage" name="group_stage" context="{'group_by': 'capture_stage'}" />
                    <filter string="Engineer" name="group_engineer" context="{'group_by': 'engineer_id'}" />
                    <filter string="Customer" name="group_customer" context="{'group_by': 'partner_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_evidence_tree" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.evidence.tree</field>
        <field name="model">helpdesk.dispatch.evidence</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="dispatch_id" />
                <field name="evidence_type" />
                <field name="capture_stage" />
                <field name="captured_on" />
                <field name="engineer_id" />
                <field name="file_name" optional="show" />
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_evidence_form" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.evidence.form</field>
        <field name="model">helpdesk.dispatch.evidence</field>
        <field name="arch" type="xml">
            <form string="Dispatch Evidence">
                <sheet>
                    <group>
                        <group>
                            <field name="dispatch_id" />
                            <field name="ticket_id" readonly="1" />
                            <field name="partner_id" readonly="1" />
                            <field name="engineer_id" />
                        </group>
                        <group>
                            <field name="evidence_type" />
                            <field name="capture_stage" />
                            <field name="captured_on" />
                            <field name="is_photo" readonly="1" />
                        </group>
                    </group>
                    <group>
                        <field name="name" />
                        <field name="note" />
                    </group>
                    <group>
                        <field name="file_data" filename="file_name" />
                        <field name="file_name" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_dispatch_evidence" model="ir.actions.act_window">
        <field name="name">Dispatch Evidence</field>
        <field name="res_model">helpdesk.dispatch.evidence</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_helpdesk_dispatch_evidence_search" />
    </record>

    <record id="view_helpdesk_dispatch_search_execution" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.search.execution</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="inherit_id" ref="helpdesk_custom_dispatch.view_helpdesk_dispatch_search" />
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="Ready to Close" name="ready_to_close" domain="[('ready_for_completion', '=', True)]" />
                <filter string="Pending Sign-off" name="pending_signoff" domain="[('customer_signoff_required', '=', True), ('signoff_status', '=', 'pending')]" />
                <filter string="Missing Evidence" name="missing_evidence" domain="[('evidence_required', '=', True), ('evidence_count', '=', 0)]" />
            </xpath>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_tree_execution" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.tree.execution</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="inherit_id" ref="helpdesk_custom_dispatch.view_helpdesk_dispatch_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='planned_hours']" position="after">
                <field name="travel_duration_hours" optional="show" />
                <field name="onsite_duration_hours" optional="show" />
                <field name="evidence_count" optional="show" />
                <field name="signoff_status" optional="show" />
            </xpath>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_form_execution" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.form.execution</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="inherit_id" ref="helpdesk_custom_dispatch.view_helpdesk_dispatch_form" />
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_check_in']" position="after">
                <button name="action_leave_site" type="object" string="Leave Site" invisible="state != 'on_site'" groups="helpdesk_mgmt.group_helpdesk_user" />
            </xpath>
            <xpath expr="//header/field[@name='state']" position="before">
                <button name="action_mark_signoff_received" type="object" string="Mark Signed" invisible="customer_signoff_required == False or signoff_status == 'signed' or state not in ('on_site', 'completed', 'no_access')" groups="helpdesk_mgmt.group_helpdesk_user" />
                <button name="action_mark_signoff_declined" type="object" string="Sign-off Declined" invisible="customer_signoff_required == False or signoff_status == 'declined' or state not in ('on_site', 'completed', 'no_access')" groups="helpdesk_mgmt.group_helpdesk_user" />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_evidence" type="object" class="oe_stat_button" icon="fa-camera">
                    <field name="evidence_count" widget="statinfo" string="Evidence" />
                </button>
            </xpath>
            <xpath expr="//group[field[@name='actual_end']]" position="after">
                <group string="Execution Timing">
                    <field name="travel_start_at" />
                    <field name="arrival_at" />
                    <field name="departure_at" />
                    <field name="travel_duration_hours" readonly="1" />
                    <field name="onsite_duration_hours" readonly="1" />
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Execution Control">
                    <group>
                        <group string="Pre-Departure Checklist">
                            <field name="pre_departure_customer_confirmed" />
                            <field name="pre_departure_tools_ready" />
                            <field name="pre_departure_scope_confirmed" />
                            <field name="pre_departure_asset_checked" />
                            <field name="pre_departure_completion" readonly="1" />
                            <field name="ready_for_departure" readonly="1" />
                        </group>
                        <group string="On-Site Checklist">
                            <field name="onsite_access_confirmed" />
                            <field name="onsite_issue_validated" />
                            <field name="onsite_customer_briefed" />
                            <field name="onsite_work_documented" />
                            <field name="evidence_logged" readonly="1" />
                            <field name="onsite_completion" readonly="1" />
                            <field name="ready_for_completion" readonly="1" />
                        </group>
                    </group>
                    <group string="Sign-off and Completion">
                        <group>
                            <field name="customer_signoff_required" />
                            <field name="signoff_status" />
                            <field name="signoff_at" />
                        </group>
                        <group>
                            <field name="signoff_contact_name" />
                            <field name="signoff_contact_role" />
                            <field name="latest_evidence_on" readonly="1" />
                        </group>
                    </group>
                    <group>
                        <field name="signoff_notes" placeholder="Customer acceptance detail, exception, or sign-off note..." />
                    </group>
                </page>
                <page string="Execution Evidence">
                    <field name="evidence_ids" context="{'default_engineer_id': engineer_id, 'default_dispatch_id': id}">
                        <tree editable="bottom">
                            <field name="name" />
                            <field name="evidence_type" />
                            <field name="capture_stage" />
                            <field name="captured_on" />
                            <field name="engineer_id" />
                            <field name="file_data" filename="file_name" />
                            <field name="file_name" invisible="1" />
                            <field name="note" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
