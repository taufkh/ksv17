<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_contract_renewal_search" model="ir.ui.view">
        <field name="name">helpdesk.contract.renewal.search</field>
        <field name="model">helpdesk.contract.renewal</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="contract_id" />
                <field name="partner_id" />
                <field name="sales_user_id" />
                <filter string="Open" name="open" domain="[('state', '=', 'open')]" />
                <filter string="In Review" name="in_review" domain="[('state', '=', 'in_review')]" />
                <filter string="Handoff Sent" name="handoff_sent" domain="[('state', '=', 'handoff_sent')]" />
                <filter string="Expiring Soon" name="expiring_soon" domain="[('days_to_expiry', '&lt;=', 14), ('state', 'not in', ['won', 'lost', 'dismissed'])]" />
                <filter string="Low Hours" name="low_hours" domain="[('low_hours_alert', '=', True), ('state', 'not in', ['won', 'lost', 'dismissed'])]" />
                <filter string="Critical" name="critical" domain="[('risk_level', '=', 'critical')]" />
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}" />
                    <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                    <filter string="Risk" name="group_risk" context="{'group_by': 'risk_level'}" />
                    <filter string="Trigger" name="group_trigger" context="{'group_by': 'trigger_type'}" />
                    <filter string="Team" name="group_team" context="{'group_by': 'team_id'}" />
                    <filter string="Salesperson" name="group_sales_user" context="{'group_by': 'sales_user_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_helpdesk_contract_renewal_tree" model="ir.ui.view">
        <field name="name">helpdesk.contract.renewal.tree</field>
        <field name="model">helpdesk.contract.renewal</field>
        <field name="arch" type="xml">
            <tree decoration-danger="risk_level == 'critical'" decoration-warning="risk_level in ('high', 'medium')">
                <field name="name" />
                <field name="contract_id" />
                <field name="partner_id" />
                <field name="trigger_type" />
                <field name="risk_level" />
                <field name="days_to_expiry" optional="show" />
                <field name="remaining_hours" optional="show" />
                <field name="renewal_probability" optional="show" />
                <field name="sales_user_id" optional="show" />
                <field name="next_follow_up_date" />
                <field name="state" />
                <field name="handoff_id" optional="show" />
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_contract_renewal_form" model="ir.ui.view">
        <field name="name">helpdesk.contract.renewal.form</field>
        <field name="model">helpdesk.contract.renewal</field>
        <field name="arch" type="xml">
            <form string="Contract Renewal">
                <header>
                    <button name="action_mark_in_review" type="object" string="Start Review" class="btn-primary" invisible="state != 'open'" groups="helpdesk_mgmt.group_helpdesk_user" />
                    <button name="action_create_sales_handoff" type="object" string="Create Sales Handoff" class="btn-primary" invisible="state not in ('open', 'in_review') or handoff_id" groups="helpdesk_mgmt.group_helpdesk_user,sales_team.group_sale_salesman" />
                    <button name="action_open_handoff" type="object" string="Open Sales Handoff" invisible="not handoff_id" groups="helpdesk_mgmt.group_helpdesk_user,sales_team.group_sale_salesman" />
                    <button name="action_mark_won" type="object" string="Mark Won" invisible="state in ('won', 'dismissed')" groups="sales_team.group_sale_salesman,helpdesk_mgmt.group_helpdesk_manager" />
                    <button name="action_mark_lost" type="object" string="Mark Lost" invisible="state in ('lost', 'dismissed')" groups="sales_team.group_sale_salesman,helpdesk_mgmt.group_helpdesk_manager" />
                    <button name="action_dismiss" type="object" string="Dismiss" invisible="state == 'dismissed'" groups="helpdesk_mgmt.group_helpdesk_manager" />
                    <button name="action_reset_open" type="object" string="Reset To Open" invisible="state not in ('won', 'lost', 'dismissed', 'handoff_sent')" groups="helpdesk_mgmt.group_helpdesk_manager" />
                    <field name="state" widget="statusbar" statusbar_visible="open,in_review,handoff_sent,won,lost,dismissed" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_contract" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <span class="o_stat_text">Open Contract</span>
                        </button>
                        <button name="action_open_handoff" type="object" class="oe_stat_button" icon="fa-briefcase" invisible="not handoff_id">
                            <span class="o_stat_text">Open Handoff</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1><field name="name" /></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contract_id" />
                            <field name="partner_id" readonly="1" />
                            <field name="team_id" readonly="1" />
                            <field name="trigger_type" />
                            <field name="risk_level" readonly="1" />
                            <field name="owner_id" />
                        </group>
                        <group>
                            <field name="sales_team_id" />
                            <field name="sales_user_id" />
                            <field name="latest_ticket_id" readonly="1" />
                            <field name="handoff_id" readonly="1" />
                            <field name="next_follow_up_date" />
                            <field name="is_auto_generated" />
                        </group>
                    </group>
                    <group string="Contract Signal">
                        <group>
                            <field name="contract_state" readonly="1" />
                            <field name="end_date" readonly="1" />
                            <field name="days_to_expiry" readonly="1" />
                            <field name="threshold_reached" readonly="1" />
                        </group>
                        <group>
                            <field name="included_hours" readonly="1" />
                            <field name="remaining_hours" readonly="1" />
                            <field name="warning_hours" readonly="1" />
                            <field name="low_hours_alert" readonly="1" />
                        </group>
                    </group>
                    <group string="Commercial Planning">
                        <group>
                            <field name="renewal_probability" />
                            <field name="expected_revenue" />
                        </group>
                        <group>
                            <field name="decision_note" placeholder="Outcome, pricing position, blockers, or renewal decision details..." />
                        </group>
                    </group>
                    <notebook>
                        <page string="Context">
                            <field name="commercial_note" widget="html" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_contract_renewal_pivot" model="ir.ui.view">
        <field name="name">helpdesk.contract.renewal.pivot</field>
        <field name="model">helpdesk.contract.renewal</field>
        <field name="arch" type="xml">
            <pivot string="Contract Renewal Analysis">
                <field name="partner_id" type="row" />
                <field name="risk_level" type="col" />
                <field name="renewal_probability" type="measure" />
                <field name="expected_revenue" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="view_helpdesk_contract_renewal_graph" model="ir.ui.view">
        <field name="name">helpdesk.contract.renewal.graph</field>
        <field name="model">helpdesk.contract.renewal</field>
        <field name="arch" type="xml">
            <graph string="Contract Renewal Trends" type="bar">
                <field name="risk_level" />
                <field name="expected_revenue" type="measure" />
                <field name="renewal_probability" type="measure" />
            </graph>
        </field>
    </record>

    <record id="action_helpdesk_contract_renewal" model="ir.actions.act_window">
        <field name="name">Contract Renewals</field>
        <field name="res_model">helpdesk.contract.renewal</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_helpdesk_contract_renewal_search" />
        <field name="context">{'search_default_open': 1}</field>
    </record>

    <menuitem
        id="menu_helpdesk_contract_renewal"
        name="Contract Renewals"
        parent="helpdesk_mgmt.helpdesk_ticket_reporting_menu"
        action="action_helpdesk_contract_renewal"
        sequence="44"
        groups="helpdesk_mgmt.group_helpdesk_user,sales_team.group_sale_salesman"
    />

    <record id="ir_cron_helpdesk_contract_renewal_sync" model="ir.cron">
        <field name="name">Helpdesk Contract Renewal Sync</field>
        <field name="model_id" ref="model_helpdesk_contract_renewal" />
        <field name="state">code</field>
        <field name="code">model.cron_sync_contract_renewals()</field>
        <field name="interval_number">4</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>
</odoo>
