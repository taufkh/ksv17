<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_support_asset_search" model="ir.ui.view">
        <field name="name">helpdesk.support.asset.search</field>
        <field name="model">helpdesk.support.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="partner_id" />
                <field name="support_contract_id" />
                <field name="site_name" />
                <field name="reference_code" />
                <filter string="Covered" name="covered" domain="[('coverage_status', '=', 'covered')]" />
                <filter string="Needs Attention" name="needs_attention" domain="[('coverage_status', 'in', ['warning', 'expired', 'suspended', 'uncovered'])]" />
                <filter string="Open Issues" name="open_issues" domain="[('open_ticket_count', '&gt;', 0)]" />
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}" />
                    <filter string="Asset Type" name="group_asset_type" context="{'group_by': 'asset_type'}" />
                    <filter string="Coverage" name="group_coverage" context="{'group_by': 'coverage_status'}" />
                    <filter string="Service Level" name="group_service_level" context="{'group_by': 'service_level'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_helpdesk_support_asset_tree" model="ir.ui.view">
        <field name="name">helpdesk.support.asset.tree</field>
        <field name="model">helpdesk.support.asset</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="partner_id" />
                <field name="asset_type" />
                <field name="site_name" optional="show" />
                <field name="reference_code" optional="show" />
                <field name="support_contract_id" optional="show" />
                <field name="coverage_status" />
                <field name="open_ticket_count" optional="show" />
                <field name="dispatch_count" optional="show" />
                <field name="state" />
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_support_asset_form" model="ir.ui.view">
        <field name="name">helpdesk.support.asset.form</field>
        <field name="model">helpdesk.support.asset</field>
        <field name="arch" type="xml">
            <form string="Support Asset">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_tickets" type="object" class="oe_stat_button" icon="fa-life-ring">
                            <field name="ticket_count" widget="statinfo" string="Tickets" />
                        </button>
                        <button name="action_open_dispatches" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="dispatch_count" widget="statinfo" string="Dispatches" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1><field name="name" /></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" />
                            <field name="support_contract_id" />
                            <field name="asset_type" />
                            <field name="service_level" />
                            <field name="state" />
                        </group>
                        <group>
                            <field name="site_name" />
                            <field name="reference_code" />
                            <field name="serial_number" />
                            <field name="location" />
                            <field name="coverage_status" readonly="1" />
                        </group>
                    </group>
                    <group string="Support Health">
                        <group>
                            <field name="ticket_count" readonly="1" />
                            <field name="open_ticket_count" readonly="1" />
                            <field name="overdue_ticket_count" readonly="1" />
                        </group>
                        <group>
                            <field name="dispatch_count" readonly="1" />
                            <field name="active_dispatch_count" readonly="1" />
                            <field name="last_ticket_update" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" widget="html" />
                        </page>
                        <page string="Tickets">
                            <field name="ticket_ids" readonly="1">
                                <tree>
                                    <field name="number" />
                                    <field name="name" />
                                    <field name="stage_id" />
                                    <field name="user_id" />
                                    <field name="contract_coverage_status" />
                                </tree>
                            </field>
                        </page>
                        <page string="Dispatches">
                            <field name="dispatch_ids" readonly="1">
                                <tree>
                                    <field name="name" />
                                    <field name="dispatch_type" />
                                    <field name="engineer_id" />
                                    <field name="scheduled_start" />
                                    <field name="state" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_support_asset_pivot" model="ir.ui.view">
        <field name="name">helpdesk.support.asset.pivot</field>
        <field name="model">helpdesk.support.asset</field>
        <field name="arch" type="xml">
            <pivot string="Support Asset Analysis">
                <field name="partner_id" type="row" />
                <field name="coverage_status" type="col" />
                <field name="ticket_count" type="measure" />
                <field name="open_ticket_count" type="measure" />
                <field name="dispatch_count" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="action_helpdesk_support_asset" model="ir.actions.act_window">
        <field name="name">Support Assets</field>
        <field name="res_model">helpdesk.support.asset</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="search_view_id" ref="view_helpdesk_support_asset_search" />
    </record>

    <menuitem
        id="menu_helpdesk_support_asset"
        name="Support Assets"
        parent="helpdesk_mgmt.helpdesk_ticket_config_main_menu"
        action="action_helpdesk_support_asset"
        sequence="56"
        groups="helpdesk_mgmt.group_helpdesk_user"
    />
</odoo>
