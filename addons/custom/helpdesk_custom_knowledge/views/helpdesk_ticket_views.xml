<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_ticket_search_knowledge" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search.knowledge</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.helpdesk_ticket_view_search" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='high_priority']" position="after">
                <filter string="Has Knowledge" name="has_knowledge" domain="[('knowledge_article_ids', '!=', False)]" />
            </xpath>
        </field>
    </record>

    <record id="view_helpdesk_ticket_form_knowledge" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.knowledge</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_create_knowledge_article"
                    type="object"
                    string="Create Knowledge Article"
                    groups="helpdesk_mgmt.group_helpdesk_user"
                />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_knowledge_articles"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-book"
                    groups="helpdesk_mgmt.group_helpdesk_user"
                >
                    <field name="knowledge_article_count" widget="statinfo" string="Knowledge" />
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Knowledge">
                    <group>
                        <field
                            name="knowledge_article_ids"
                            widget="many2many_tags"
                            options="{'no_create': True}"
                            context="{'default_is_helpdesk_article': True}"
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
