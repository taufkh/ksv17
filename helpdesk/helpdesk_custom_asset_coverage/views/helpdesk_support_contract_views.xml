<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_support_contract_form_asset" model="ir.ui.view">
        <field name="name">helpdesk.support.contract.form.asset</field>
        <field name="model">helpdesk.support.contract</field>
        <field name="inherit_id" ref="helpdesk_custom_contract.view_helpdesk_support_contract_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_assets" type="object" class="oe_stat_button" icon="fa-cubes">
                    <field name="asset_count" widget="statinfo" string="Assets" />
                </button>
            </xpath>
            <xpath expr="//field[@name='covered_ticket_count']/ancestor::group[1]" position="inside">
                <field name="asset_count" readonly="1" />
                <field name="active_asset_count" readonly="1" />
            </xpath>
            <xpath expr="//field[@name='ticket_ids']/ancestor::page[1]" position="after">
                <page string="Assets">
                    <field name="asset_ids" readonly="1">
                        <tree>
                            <field name="name" />
                            <field name="asset_type" />
                            <field name="site_name" />
                            <field name="reference_code" />
                            <field name="coverage_status" />
                            <field name="open_ticket_count" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
