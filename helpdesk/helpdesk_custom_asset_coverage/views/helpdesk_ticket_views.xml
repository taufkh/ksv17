<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_ticket_search_asset" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search.asset</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.helpdesk_ticket_view_search" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='high_priority']" position="after">
                <filter string="Has Asset" name="has_asset" domain="[('support_asset_id', '!=', False)]" />
                <filter string="Uncovered Asset" name="asset_uncovered" domain="[('support_asset_coverage_status', 'in', ['uncovered', 'expired', 'suspended'])]" />
            </xpath>
        </field>
    </record>

    <record id="view_helpdesk_ticket_form_asset" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.asset</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_reassign_support_asset"
                    type="object"
                    string="Refresh Asset"
                    groups="helpdesk_mgmt.group_helpdesk_user"
                />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_support_asset"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-cubes"
                    invisible="not support_asset_id"
                    groups="helpdesk_mgmt.group_helpdesk_user"
                >
                    <span class="o_stat_text">Support Asset</span>
                </button>
            </xpath>
            <xpath expr="//page[@name='other_info']/group" position="inside">
                <field name="support_asset_id" />
                <field name="support_asset_state" readonly="1" />
                <field name="support_asset_coverage_status" readonly="1" />
            </xpath>
        </field>
    </record>
</odoo>
