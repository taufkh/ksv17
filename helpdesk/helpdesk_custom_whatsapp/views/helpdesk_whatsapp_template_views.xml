<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_whatsapp_template_tree" model="ir.ui.view">
        <field name="name">helpdesk.whatsapp.template.tree</field>
        <field name="model">helpdesk.whatsapp.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" />
                <field name="name" />
                <field name="trigger" />
                <field name="recipient_type" />
                <field name="team_id" optional="show" />
                <field name="company_id" optional="show" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_whatsapp_template_form" model="ir.ui.view">
        <field name="name">helpdesk.whatsapp.template.form</field>
        <field name="model">helpdesk.whatsapp.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="active" />
                            <field name="sequence" />
                            <field name="trigger" />
                        </group>
                        <group>
                            <field name="recipient_type" />
                            <field name="team_id" />
                            <field name="company_id" />
                        </group>
                    </group>
                    <group>
                        <field name="body_template" nolabel="1" widget="text" />
                    </group>
                    <group string="Placeholder Reference">
                        <div class="o_form_label">
                            {ticket_number}, {ticket_name}, {stage_name}, {team_name}, {partner_name}, {assignee_name}, {priority_name}, {sla_label}, {public_portal_url}, {rule_name}, {event_reason}, {changed_by_name}, {closed_date}
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_whatsapp_template_search" model="ir.ui.view">
        <field name="name">helpdesk.whatsapp.template.search</field>
        <field name="model">helpdesk.whatsapp.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="trigger" />
                <field name="recipient_type" />
                <field name="team_id" />
                <filter name="active_templates" string="Active" domain="[('active', '=', True)]" />
                <group expand="0" string="Group By">
                    <filter name="group_trigger" string="Trigger" context="{'group_by': 'trigger'}" />
                    <filter name="group_team" string="Team" context="{'group_by': 'team_id'}" />
                    <filter name="group_recipient" string="Recipient" context="{'group_by': 'recipient_type'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_helpdesk_whatsapp_template" model="ir.actions.act_window">
        <field name="name">WhatsApp Templates</field>
        <field name="res_model">helpdesk.whatsapp.template</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_helpdesk_whatsapp_template_search" />
    </record>

    <menuitem
        id="menu_helpdesk_whatsapp_templates"
        name="WhatsApp Templates"
        parent="helpdesk_mgmt.helpdesk_ticket_config_main_menu"
        action="action_helpdesk_whatsapp_template"
        sequence="55"
        groups="helpdesk_mgmt.group_helpdesk_manager"
    />
</odoo>
