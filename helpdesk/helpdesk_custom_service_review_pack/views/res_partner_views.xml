<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_partner_form_helpdesk_service_review_pack" model="ir.ui.view">
        <field name="name">res.partner.form.helpdesk.service.review.pack</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="helpdesk_custom_customer_360.view_partner_form_helpdesk_360" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_helpdesk_service_review_packs" type="object" class="oe_stat_button" icon="fa-file-pdf-o" groups="helpdesk_mgmt.group_helpdesk_user">
                    <field name="helpdesk_service_review_pack_count" widget="statinfo" string="Service Reviews" />
                </button>
                <button name="action_generate_helpdesk_service_review_pack" type="object" class="oe_stat_button" icon="fa-plus-square-o" groups="helpdesk_mgmt.group_helpdesk_user">
                    <span class="o_stat_text">Generate Review</span>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
