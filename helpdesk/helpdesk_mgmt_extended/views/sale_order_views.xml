<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_order_form_ext" model="ir.ui.view">
        <field name="name">sale.order.form.helpdesk</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_tickets" type="object"
                        class="oe_stat_button" icon="fa-ticket"
                        invisible="ticket_count == 0">
                    <field name="ticket_count" widget="statinfo" string="Tickets"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
