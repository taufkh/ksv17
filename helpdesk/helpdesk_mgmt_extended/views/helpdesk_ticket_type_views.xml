<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_ticket_type_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.list</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <list string="Ticket Types">
                <field name="name"/>
                <field name="team_ids" widget="many2many_tags"/>
                <field name="show_in_portal"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_ticket_type_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.form</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <form string="Ticket Type">
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="show_in_portal"/>
                        <field name="team_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_ticket_type" model="ir.actions.act_window">
        <field name="name">Ticket Types</field>
        <field name="res_model">helpdesk.ticket.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
