<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_ticket_create_lead_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.create.lead.form</field>
        <field name="model">helpdesk.ticket.create.lead</field>
        <field name="arch" type="xml">
            <form string="Create Lead / Opportunity">
                <group>
                    <field name="ticket_id" readonly="1"/>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="team_id"/>
                    <field name="user_id"/>
                    <field name="description"/>
                </group>
                <footer>
                    <button name="action_create_lead" type="object"
                            string="Create Lead" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
