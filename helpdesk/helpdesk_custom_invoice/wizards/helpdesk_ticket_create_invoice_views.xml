<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_ticket_create_invoice_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.create.invoice.wizard.form</field>
        <field name="model">helpdesk.ticket.create.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Invoice">
                <group>
                    <group>
                        <field name="ticket_id" readonly="1" />
                        <field name="partner_id" />
                        <field name="invoice_date" />
                    </group>
                    <group>
                        <field name="grouping" />
                        <field name="line_count" readonly="1" />
                        <field name="uninvoiced_hours" widget="float_time" readonly="1" />
                    </group>
                </group>
                <footer>
                    <button name="action_create_invoice" type="object" string="Create Invoice" class="btn-primary" />
                    <button string="Cancel" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
