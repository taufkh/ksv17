<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_dispatch_search" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.search</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="ticket_id" />
                <field name="partner_id" />
                <field name="engineer_id" />
                <field name="approval_id" />
                <filter string="Scheduled" name="scheduled" domain="[('state', '=', 'scheduled')]" />
                <filter string="In Progress" name="in_progress" domain="[('state', 'in', ['en_route', 'on_site'])]" />
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]" />
                <filter string="Needs Follow-up" name="followup" domain="[('followup_required', '=', True)]" />
                <filter string="Today" name="today" domain="[('scheduled_start', '&gt;=', context_today().strftime('%%Y-%%m-%%d 00:00:00')), ('scheduled_start', '&lt;=', context_today().strftime('%%Y-%%m-%%d 23:59:59'))]" />
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                    <filter string="Engineer" name="group_engineer" context="{'group_by': 'engineer_id'}" />
                    <filter string="Type" name="group_type" context="{'group_by': 'dispatch_type'}" />
                    <filter string="Team" name="group_team" context="{'group_by': 'team_id'}" />
                    <filter string="Customer" name="group_customer" context="{'group_by': 'partner_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_tree" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.tree</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="ticket_id" />
                <field name="partner_id" optional="show" />
                <field name="dispatch_type" />
                <field name="urgency" />
                <field name="engineer_id" />
                <field name="scheduled_start" />
                <field name="scheduled_end" optional="show" />
                <field name="planned_hours" optional="show" />
                <field name="resolution_status" optional="show" />
                <field name="state" />
            </tree>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_form" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.form</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="arch" type="xml">
            <form string="Dispatch">
                <header>
                    <button name="action_schedule" type="object" string="Schedule" class="btn-primary" invisible="state not in ('draft', 'cancelled')" groups="helpdesk_mgmt.group_helpdesk_user" />
                    <button name="action_mark_en_route" type="object" string="En Route" invisible="state not in ('draft', 'scheduled')" groups="helpdesk_mgmt.group_helpdesk_user" />
                    <button name="action_check_in" type="object" string="Check In" invisible="state not in ('draft', 'scheduled', 'en_route')" groups="helpdesk_mgmt.group_helpdesk_user" />
                    <button name="action_complete" type="object" string="Complete" class="btn-primary" invisible="state not in ('scheduled', 'en_route', 'on_site')" groups="helpdesk_mgmt.group_helpdesk_user" />
                    <button name="action_mark_no_access" type="object" string="No Access" invisible="state not in ('scheduled', 'en_route', 'on_site')" groups="helpdesk_mgmt.group_helpdesk_user" />
                    <button name="action_cancel" type="object" string="Cancel" invisible="state not in ('draft', 'scheduled', 'en_route', 'on_site')" groups="helpdesk_mgmt.group_helpdesk_user" />
                    <button name="action_reset_draft" type="object" string="Reset Draft" invisible="state in ('draft', 'completed')" groups="helpdesk_mgmt.group_helpdesk_manager" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,en_route,on_site,completed,no_access,cancelled" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_ticket" type="object" class="oe_stat_button" icon="fa-life-ring">
                            <span class="o_stat_text">Open Ticket</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1><field name="name" /></h1>
                    </div>
                    <group>
                        <group>
                            <field name="ticket_id" />
                            <field name="partner_id" readonly="1" />
                            <field name="team_id" readonly="1" />
                            <field name="ticket_user_id" readonly="1" />
                            <field name="approval_id" />
                        </group>
                        <group>
                            <field name="dispatch_type" />
                            <field name="urgency" />
                            <field name="engineer_id" />
                            <field name="resolution_status" />
                            <field name="followup_required" />
                        </group>
                    </group>
                    <group string="Schedule">
                        <group>
                            <field name="scheduled_start" />
                            <field name="scheduled_end" />
                            <field name="planned_hours" readonly="1" />
                        </group>
                        <group>
                            <field name="actual_start" />
                            <field name="actual_end" />
                            <field name="actual_hours" readonly="1" />
                        </group>
                    </group>
                    <group string="Site Details">
                        <group>
                            <field name="location" />
                            <field name="site_contact_name" />
                            <field name="site_contact_phone" />
                        </group>
                        <group>
                            <field name="travel_required" />
                            <field name="project_id" readonly="1" />
                            <field name="task_id" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Work Summary">
                            <field name="work_summary" widget="html" />
                        </page>
                        <page string="Visit Findings">
                            <field name="visit_findings" widget="html" />
                        </page>
                        <page string="Follow-up">
                            <field name="followup_action" placeholder="Next action, dependency, or revisit note..." />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_calendar" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.calendar</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="arch" type="xml">
            <calendar string="Dispatch Calendar" date_start="scheduled_start" date_stop="scheduled_end" color="engineer_id" mode="month" quick_create="false">
                <field name="name" />
                <field name="ticket_id" />
                <field name="engineer_id" />
                <field name="dispatch_type" />
                <field name="state" />
                <field name="location" />
            </calendar>
        </field>
    </record>

    <record id="view_helpdesk_dispatch_pivot" model="ir.ui.view">
        <field name="name">helpdesk.dispatch.pivot</field>
        <field name="model">helpdesk.dispatch</field>
        <field name="arch" type="xml">
            <pivot string="Dispatch Analysis">
                <field name="engineer_id" type="row" />
                <field name="state" type="col" />
                <field name="id" type="measure" string="Dispatches" />
                <field name="planned_hours" type="measure" />
                <field name="actual_hours" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="action_helpdesk_dispatch" model="ir.actions.act_window">
        <field name="name">Dispatch Board</field>
        <field name="res_model">helpdesk.dispatch</field>
        <field name="view_mode">tree,calendar,form,pivot</field>
        <field name="search_view_id" ref="view_helpdesk_dispatch_search" />
        <field name="context">{'search_default_scheduled': 1}</field>
    </record>

    <menuitem
        id="menu_helpdesk_dispatch"
        name="Dispatch Board"
        parent="helpdesk_mgmt.helpdesk_ticket_reporting_menu"
        action="action_helpdesk_dispatch"
        sequence="40"
        groups="helpdesk_mgmt.group_helpdesk_user"
    />
</odoo>
