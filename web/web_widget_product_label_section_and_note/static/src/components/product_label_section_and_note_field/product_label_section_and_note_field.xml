<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="web_widget_product_label_section_and_note.ProductLabel">
        <textarea
            class="o_input d-print-none border-0 fst-italic"
            placeholder="Enter a description"
            t-att-readonly="props.readonly"
            rows="1"
            type="text"
            t-att-class="sectionAndNoteClasses"
            t-att-value="label"
            t-on-change="(ev) => this.updateLabel(ev.target.value)"
            t-ref="labelNodeRef"
        />
    </t>
    <t t-name="web_widget_product_label_section_and_note.ProductLabelVisibilityButton">
        <button
            t-if="!label"
            class="btn fa fa-bars text-start o_external_button px-1"
            data-tooltip="Click or press enter to add a description"
            id="labelVisibilityButtonId"
            type="button"
            t-on-click="switchLabelVisibility"
        />
        <button
            t-if="label"
            t-att-class="'btn text-start o_external_button px-1 fa ' + ( this.props.isProductVisible ? 'fa-eye' : 'fa-eye-slash')"
            data-tooltip="Click to remove/add the product name from the description."
            id="ProductVisibilityButtonId"
            type="button"
            t-on-click="switchProductVisibility"
        />
    </t>
    <t
        t-name="web_widget_product_label_section_and_note.ProductLabelSectionAndNoteField"
        t-inherit="web.Many2OneField"
        t-inherit-mode="primary"
    >
        <xpath expr="//t[@t-if='props.readonly']//span" position="attributes">
            <attribute
                name="class"
            >d-flex align-items-center justify-content-between</attribute>
        </xpath>
        <xpath expr="//t[@t-if='props.readonly']//a" position="attributes">
            <attribute
                name="class"
            >d-flex align-items-center justify-content-between</attribute>
        </xpath>
        <xpath expr="//t[@t-if='props.readonly']" position="inside">
            <t t-if="!isSectionOrNote">
                <ProductLabel
                    t-if="(columnIsProductAndLabel.value and label) or (!columnIsProductAndLabel.value and !productName and label)"
                    label="() => this.label"
                    updateLabel="(value) => this.updateLabel(value)"
                    field_name="this.props.name"
                    readonly="true"
                    record="this.props.record"
                />
            </t>
            <t t-else="">
                <ProductLabel
                    field_name="this.props.name"
                    label="() => this.label"
                    updateLabel="(value) => this.updateLabel(value)"
                    record="this.props.record"
                />
            </t>
        </xpath>
        <xpath expr="//button[@t-if='hasBarcodeButton']" position="after">
            <t t-if="!isSectionOrNote">
                <ProductLabelVisibilityButton
                    t-if="columnIsProductAndLabel.value"
                    label="() => this.label"
                    isProductVisible="this.isProductVisible.value"
                    switchLabelVisibility="() => this.switchLabelVisibility()"
                    switchProductVisibility="() => this.switchProductVisibility()"
                />
            </t>
        </xpath>
        <xpath expr="//div[hasclass('o_field_many2one_selection')]" position="after">
            <t t-if="!isSectionOrNote">
                <t
                    t-if="columnIsProductAndLabel.value and (label or labelVisibility.value)"
                >
                    <ProductLabel
                        label="() => this.label"
                        field_name="this.props.name"
                        updateLabel="(value) => this.updateLabel(value)"
                        record="this.props.record"
                    />
                </t>
            </t>
            <t t-else="">
                <ProductLabel
                    field_name="this.props.name"
                    label="() => this.label"
                    updateLabel="(value) => this.updateLabel(value)"
                    record="this.props.record"
                />
            </t>
        </xpath>
        <xpath
            expr="//div[hasclass('o_field_many2one_selection')]"
            position="attributes"
        >
            <attribute
                name="class"
                separator=" "
                remove="o_field_many2one_selection"
                add="d-flex align-items-center justify-content-between"
            />
            <attribute name="t-if">!isSectionOrNote</attribute>
        </xpath>
    </t>
</templates>
